# ===============================
# COPY THIS TO .env  (never commit .env to git!)
# ===============================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/gameverse

# JWT — CHANGE THIS to a random 32+ char string before deploying!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING_BEFORE_DEPLOY
JWT_EXPIRES_IN=7d

# Redis (optional — falls back to memory)
REDIS_URL=

# CORS — set to your actual frontend URL
CLIENT_URL=http://localhost:5000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OTP / SMS (optional — integrate Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
